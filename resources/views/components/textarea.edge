<div class="field {{ flashMessages.has(`errors.${name}`) ? 'error' : '' }}">
  @if(label)
    <label>{{ label }}</label>
  @end
  
  <textarea 
    name="{{ name }}" 
    rows="{{ rows || 3 }}"
    {{ required ? 'required' : '' }}
    placeholder="{{ placeholder || '' }}"
    >{{ old(name) || value || '' }}
  </textarea>

  @if(flashMessages.has(`errors.${name}`))
    <div class="ui pointing red basic label">
      {{ flashMessages.get(`errors.${name}`) }}
    </div>
  @end
</div>
